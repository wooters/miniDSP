# miniDSP Doxygen configuration

PROJECT_NAME           = "miniDSP"
PROJECT_BRIEF          = "A small C library for audio DSP"
OUTPUT_DIRECTORY       = docs

# --- Input ---
INPUT                  = include src README.md guides
FILE_PATTERNS          = *.h *.c *.md
RECURSIVE              = NO
EXCLUDE                = doxygen-awesome-css tests
USE_MDFILE_AS_MAINPAGE = README.md
EXAMPLE_PATH           = examples tools/audio_steg tools/resample
IMAGE_PATH             = guides/images

# --- C optimizations ---
OPTIMIZE_OUTPUT_FOR_C  = YES
JAVADOC_AUTOBRIEF      = YES
EXTRACT_STATIC         = YES
TYPEDEF_HIDES_STRUCT   = YES

# --- Source browsing ---
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO

# --- HTML output with Doxygen Awesome theme ---
